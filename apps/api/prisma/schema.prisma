// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
  guest
}

enum Status {
  active
  inactive
}

enum AttendanceStatus {
  attendance
  absent
  late
  excused
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum ToiletType {
  urination
  defecation
}

enum PetType {
  dog
  cat
  bird
  fish
  hamster
  rabbit
  other
}

enum SymptomType {
  vomiting
  coughing
  diarrhea
  skin_issue
  eye_issue
  ear_issue
  appetite_loss
  lethargy
  breathing_issue
  limping
  scratching
  sneezing
  fever
  other
}

enum Severity {
  mild
  moderate
  severe
}

enum PetUserRole {
  owner
  member
}

model User {
  id          Int      @id @default(autoincrement())
  account     String   @unique
  password    String
  username    String
  role        Role?    @default(guest)
  email       String?  @unique
  telegram_id String?  @unique
  slack_id    String?  @unique
  status      Status?  @default(active)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // 擁有的資料 (user_id 關聯)
  ownedSchools         School[]         @relation("SchoolOwner")
  ownedCourses         Course[]         @relation("CourseOwner")
  ownedStudents        Student[]        @relation("StudentOwner")
  ownedGradeSheets     GradeSheet[]     @relation("GradeSheetOwner")
  ownedAttendances     Attendance[]     @relation("AttendanceOwner")
  ownedSalaryBases     SalaryBase[]     @relation("SalaryBaseOwner")
  ownedCourseSessions  CourseSession[]  @relation("CourseSessionOwner")

  // 修改紀錄 (modifier_id 關聯)
  modifiedSchools      School[]         @relation("SchoolModifier")
  modifiedCourses      Course[]         @relation("CourseModifier")
  modifiedStudents     Student[]        @relation("StudentModifier")
  modifiedGradeSheets  GradeSheet[]     @relation("GradeSheetModifier")
  modifiedAttendances  Attendance[]     @relation("AttendanceModifier")
  modifiedSalaryBases  SalaryBase[]     @relation("SalaryBaseModifier")
  modifiedCourseSessions CourseSession[] @relation("CourseSessionModifier")

  // Pet & Health 擁有 (user_id 關聯)
  pets                 Pet[]            @relation("PetOwner")
  healthWeights        HealthWeight[]   @relation("HealthWeightOwner")
  healthDiets          HealthDiet[]     @relation("HealthDietOwner")
  healthToilets        HealthToilet[]   @relation("HealthToiletOwner")
  healthSymptoms       HealthSymptom[]  @relation("HealthSymptomOwner")

  // Pet & Health 修改紀錄 (modifier_id 關聯)
  modifiedPets         Pet[]            @relation("PetModifier")
  modifiedHealthWeights  HealthWeight[] @relation("HealthWeightModifier")
  modifiedHealthDiets    HealthDiet[]   @relation("HealthDietModifier")
  modifiedHealthToilets  HealthToilet[] @relation("HealthToiletModifier")
  modifiedHealthSymptoms HealthSymptom[] @relation("HealthSymptomModifier")

  // Pet 共享關聯 (PetUser junction table)
  petUsers             PetUser[]

  auditLogs            AuditLog[]
}

model School {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  address     String?
  color       String?  // 自定義顏色（HEX 格式，例如 #1677ff）
  is_active   Boolean? @default(true)
  user_id     Int?
  user        User?    @relation("SchoolOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id Int?
  modifier    User?    @relation("SchoolModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  courses        Course[]
  salaryBases    SalaryBase[]
  courseSessions CourseSession[]

  @@index([user_id])
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  grade       Int?
  school_id   Int
  school      School   @relation(fields: [school_id], references: [id], onDelete: Cascade)
  start_time  DateTime
  end_time    DateTime
  day_of_week String // 例如："1,3,5" 表示週一、三、五
  duration    Int // 課程持續時間（分鐘）
  user_id     Int?
  user        User?    @relation("CourseOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id Int?
  modifier    User?    @relation("CourseModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  students             Student[]
  courseSessions       CourseSession[]
  salaryBases          SalaryBase[]

  @@index([user_id])
}

model Student {
  id          Int      @id @default(autoincrement())
  name        String
  number      String
  gender      String
  course_id   Int
  course      Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  is_active   Boolean? @default(true)
  user_id     Int?
  user        User?    @relation("StudentOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id Int?
  modifier    User?    @relation("StudentModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  attendances Attendance[]
  gradesheets GradeSheet[]

  @@index([user_id])
}

model Attendance {
  id          Int              @id @default(autoincrement())
  student_id  Int
  student     Student          @relation(fields: [student_id], references: [id], onDelete: Cascade)
  date        DateTime
  status      AttendanceStatus
  user_id     Int?
  user        User?            @relation("AttendanceOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id Int?
  modifier    User?            @relation("AttendanceModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  @@index([user_id])
}

model GradeSheet {
  id          Int      @id @default(autoincrement())
  student_id  Int
  student     Student  @relation(fields: [student_id], references: [id], onDelete: Cascade)
  score       Float
  description String?
  exam_date   DateTime
  user_id     Int?
  user        User?    @relation("GradeSheetOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id Int?
  modifier    User?    @relation("GradeSheetModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
}

model SalaryBase {
  id           Int      @id @default(autoincrement())
  name         String
  hourly_rate  Float
  min_students Int?     // 最小人數（null 表示固定薪資）
  max_students Int?     // 最大人數（null 表示無上限）
  description  String?
  is_active    Boolean  @default(true)
  user_id      Int?
  user         User?    @relation("SalaryBaseOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id  Int?
  modifier     User?    @relation("SalaryBaseModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  schools          School[]         // 多對多：可被多個學校共用
  courses          Course[]         // 多對多：可綁定特定課程（優先於學校匹配）
  courseSessions   CourseSession[]

  @@index([user_id])
}

model CourseSession {
  id                   Int         @id @default(autoincrement())
  course_id            Int?
  course               Course?     @relation(fields: [course_id], references: [id], onDelete: Cascade)
  course_name          String?     // 代課時手動輸入的課程名稱
  school_id            Int?        // 代課時直接指定學校（用於薪資計算）
  school               School?     @relation(fields: [school_id], references: [id], onDelete: SetNull)
  duration             Int?        // 代課時手動輸入的上課時長（分鐘）
  date                 DateTime
  actual_student_count Int         @default(0)
  is_cancelled         Boolean     @default(false) // 是否停課
  salary_amount        Float?      // 計算出的薪資金額
  salary_base_id       Int?        // 匹配到的薪資級距
  salaryBase           SalaryBase? @relation(fields: [salary_base_id], references: [id], onDelete: SetNull)
  note                 String?
  user_id              Int?
  user                 User?       @relation("CourseSessionOwner", fields: [user_id], references: [id], onDelete: SetNull)
  modifier_id          Int?
  modifier             User?       @relation("CourseSessionModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  @@index([user_id])
}

model Pet {
  id          Int       @id @default(autoincrement())
  name        String
  type        PetType
  breed       String?
  gender      String?   // male / female / unknown
  birthday    DateTime?
  weight      Float?
  avatar_url  String?
  note        String?
  is_active   Boolean   @default(true)
  user_id     Int
  user        User      @relation("PetOwner", fields: [user_id], references: [id], onDelete: Cascade)
  modifier_id Int?
  modifier    User?     @relation("PetModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  healthWeights  HealthWeight[]
  healthDiets    HealthDiet[]
  healthToilets  HealthToilet[]
  healthSymptoms HealthSymptom[]
  petUsers       PetUser[]

  @@index([user_id])
}

model PetUser {
  id         Int         @id @default(autoincrement())
  pet_id     Int
  pet        Pet         @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  user_id    Int
  user       User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role       PetUserRole @default(member)
  created_at DateTime    @default(now())

  @@unique([pet_id, user_id])
  @@index([user_id])
  @@index([pet_id])
}

model HealthWeight {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation("HealthWeightOwner", fields: [user_id], references: [id], onDelete: Cascade)
  pet_id      Int?
  pet         Pet?     @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  date        DateTime
  weight      Float    // 體重（公斤）
  height      Float?   // 身高（公分）
  bmi         Float?   // BMI 值
  note        String?
  modifier_id Int?
  modifier    User?    @relation("HealthWeightModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id, pet_id, date])
}

model HealthDiet {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation("HealthDietOwner", fields: [user_id], references: [id], onDelete: Cascade)
  pet_id      Int?
  pet         Pet?     @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  date        DateTime
  meal_type   MealType // 餐別
  food_name   String   // 食物名稱
  amount      String?  // 份量描述
  calories    Float?   // 卡路里
  note        String?
  modifier_id Int?
  modifier    User?    @relation("HealthDietModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id, pet_id, date])
}

model HealthToilet {
  id          Int        @id @default(autoincrement())
  user_id     Int
  user        User       @relation("HealthToiletOwner", fields: [user_id], references: [id], onDelete: Cascade)
  pet_id      Int?
  pet         Pet?       @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  date        DateTime
  time        String     // 時間（如 "10:30"）
  type        ToiletType // 類型
  is_normal   Boolean    @default(true) // 是否正常
  note        String?
  modifier_id Int?
  modifier    User?      @relation("HealthToiletModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@index([user_id, pet_id, date])
}

model HealthSymptom {
  id                Int         @id @default(autoincrement())
  user_id           Int
  user              User        @relation("HealthSymptomOwner", fields: [user_id], references: [id], onDelete: Cascade)
  pet_id            Int?
  pet               Pet?        @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  date              DateTime
  time              String      // 時間（如 "10:30"）
  symptom_type      SymptomType
  severity          Severity
  frequency         Int         @default(1) // 發生次數
  duration_minutes  Int?        // 持續時間（分鐘）
  body_part         String?     // 身體部位
  is_recurring      Boolean     @default(false)
  description       String?     // 詳細描述
  note              String?
  modifier_id       Int?
  modifier          User?       @relation("HealthSymptomModifier", fields: [modifier_id], references: [id], onDelete: SetNull)
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  @@index([user_id, pet_id, date])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   // CREATE, UPDATE, DELETE
  entity     String   // e.g., "School", "Student", "Attendance"
  entity_id  Int?
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)
  changes    Json?    // Store what was changed
  ip_address String?
  created_at DateTime @default(now())
}
